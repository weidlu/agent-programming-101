{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug: current file",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "Debug: Phase-2 Customer Service Agent",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/phase-2/customer_service_agent.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "envFile": "${workspaceFolder}/.env",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe"
        }
    ]
}
